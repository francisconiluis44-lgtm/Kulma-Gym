# ============================================================
# Variables de entorno – Kulma Gym
# Copiá este archivo a .env.local y completá los valores
# ============================================================

# --- Supabase (públicas, seguras para el navegador) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Supabase (privada, SOLO servidor — nunca expongas esto) ---
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- OneSignal (privada, SOLO servidor) ---
ONESIGNAL_REST_API_KEY=os_v2_app_...

# --- Cron (privada, SOLO servidor) ---
# Generá un valor aleatorio largo y guardalo también en Vercel → Settings → Environment Variables
CRON_SECRET=un_secreto_largo_y_aleatorio
